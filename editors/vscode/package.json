{
  "name": "spectralint",
  "displayName": "Spectralint",
  "description": "Static analysis for AI agent instruction files (CLAUDE.md, AGENTS.md, etc.)",
  "version": "0.4.0",
  "publisher": "byallmeans",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/by-all-means/spectralint"
  },
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Linters"],
  "activationEvents": [
    "workspaceContains:**/CLAUDE.md",
    "workspaceContains:**/AGENTS.md",
    "workspaceContains:**/.claude/settings.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Spectralint",
      "properties": {
        "spectralint.path": {
          "type": "string",
          "default": "spectralint",
          "description": "Path to the spectralint binary"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "typescript": "^5.3.0"
  }
}
